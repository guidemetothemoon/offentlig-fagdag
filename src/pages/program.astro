---
import Base from '../layouts/Base.astro';
import ScheduleBlock from '../components/ScheduleBlock.astro';
import { parse } from 'yaml';
import programYaml from '../data/program.yaml?raw';

const program = parse(programYaml);

// Build aggregated "Mine favoritter" schedule: all talks across rooms, grouped by time slot, chronologically.
interface Talk {
  id: string;
  org?: string;
  title: string;
  speaker?: string;
  description?: string;
  track?: string;
}
interface Slot {
  time: string;
  duration?: string;
  talks: Talk[];
}

const slotKey = (time: string, duration?: string) => `${time}|${duration ?? ''}`;
const parseTime = (t: string): number => {
  const m = /(\d{1,2}):(\d{2})/.exec(t);
  return m ? parseInt(m[1], 10) * 60 + parseInt(m[2], 10) : 0;
};

const slots = new Map<string, Slot>();
for (const room of program.rooms) {
  for (const block of room.schedule) {
    if (!block.talks) continue;
    const key = slotKey(block.time, block.duration);
    if (!slots.has(key)) slots.set(key, { time: block.time, duration: block.duration, talks: [] });
    slots.get(key)!.talks.push(...block.talks);
  }
}
const favouriteSchedule: Slot[] = [...slots.values()].sort((a, b) => parseTime(a.time) - parseTime(b.time));
---

<Base
  title="Program – Offentlig fagdag 2026"
  description="Program for Offentlig fagdag 2026, 23. april på Meet Ullevål"
  ogTitle="Program – Offentlig fagdag 2026"
  ogDescription="Konferansen for teknologer i offentlig sektor"
  activeNav="program"
>
  <main class="program-page">
    <div class="fixed-width hero">
      <icon-manserpaakart></icon-manserpaakart>
      <div class="hero-text">
        <h1 class="ds-heading" data-size="xl">Program</h1>
        <h2 class="ds-heading" data-size="md">23. april 2026 på <a class="ds-link" href="https://meet-ullevaal.no">Meet Ullevål</a></h2>
      </div>
    </div>
    <div class="bleed">
      <div>
        <div class="schedule">
          {program.commonBefore.map((item: any) => (
            <ScheduleBlock {...item} />
          ))}
        </div>
      </div>

      <div class="ds-tabs program-tabs">
        <div role="tablist" class="program-tablist">
          {program.rooms.map((room: any, i: number) => (
            <span role="tab" aria-selected={i === 0 ? 'true' : 'false'} data-tab={room.id}>
              {room.name}<br /><small>- {room.subtitle}</small>
            </span>
          ))}
          <span role="tab" aria-selected="false" data-tab="favourites" class="program-tab-favourites js-only">
            Mine favoritter<br /><small>- stjernemerkede foredrag</small>
          </span>
        </div>
        {program.rooms.map((room: any, i: number) => (
          <div role="tabpanel" data-panel={room.id} hidden={i !== 0 ? true : undefined}>
            {room.schedule.map((block: any, j: number) => (
              <div class={j % 2 === 1 ? 'bg-tinted' : undefined}>
                <div class="schedule">
                  <ScheduleBlock {...block} />
                </div>
              </div>
            ))}
          </div>
        ))}
        <div role="tabpanel" data-panel="favourites" hidden>
          {favouriteSchedule.map((slot, j) => (
            <div class={j % 2 === 1 ? 'bg-tinted' : undefined}>
              <div class="schedule">
                <ScheduleBlock time={slot.time} duration={slot.duration} talks={slot.talks} />
              </div>
            </div>
          ))}
        </div>
      </div>

      <div>
        <div class="schedule">
          {program.commonAfter.map((item: any) => (
            <ScheduleBlock {...item} />
          ))}
        </div>
      </div>
    </div>
  </main>

  <script is:inline src="/animations.js" defer slot="scripts"></script>
</Base>

<script>
  import '../scripts/program-page.ts';
</script>
