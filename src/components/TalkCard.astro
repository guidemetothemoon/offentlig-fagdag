---
interface Props {
  id: string;
  org?: string;
  title: string;
  speaker?: string;
  description?: string;
  track?: string;
}

const { id, org, title, speaker, description, track } = Astro.props;

// Split description into paragraphs by blank lines.
const paragraphs = description
  ? description
      .split(/\n\s*\n/)
      .map(p => p.trim())
      .filter(Boolean)
  : [];
---

<div class="schedule-talk" data-talk-id={id}>
  <button
    type="button"
    class="favourite-btn js-only"
    data-talk-id={id}
    aria-pressed="false"
    aria-label="Legg til i mine favoritter"
  >
    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false" class="favourite-icon">
      <path
        d="M12 2.5l2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.8 5.9 21.1l1.4-6.8L2.2 9.6l6.9-.8L12 2.5z"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linejoin="round"
      />
    </svg>
  </button>
  {org && <span class="schedule-org">{org}</span>}
  {track && <span class="schedule-track">{track}</span>}
  <h3 class="ds-heading" data-size="sm">{title}</h3>
  {speaker && <span class="ds-paragraph schedule-speaker" data-size="sm">{speaker}</span>}
  {paragraphs.length > 0 && (
    <div class="schedule-description">
      {paragraphs.map(p => <p class="ds-paragraph" data-size="sm" set:html={p} />)}
    </div>
  )}
</div>
